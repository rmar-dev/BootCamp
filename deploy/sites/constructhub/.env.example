# Constructhub production env — used by deploy/sites/constructhub/docker-compose.yml.
# bootstrap.sh --with constructhub creates this with a random POSTGRES_PASSWORD
# and resolves CONSTRUCTHUB_REPO_PATH for you.

# Filesystem path to the Constructhub repo on the VPS.
# bootstrap.sh clones it to /opt/constructhub by default.
CONSTRUCTHUB_REPO_PATH=/opt/constructhub

# Constructhub's own Postgres credentials (independent of BootCamp's DB).
POSTGRES_USER=constructhub
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=constructhub

# If the Constructhub backend reads more env vars (Stripe keys, JWT secret,
# OAuth credentials, etc.) add them here. Mirror what
# constructhub/backend/.env.example lists. They'll be passed through to the
# `backend` service in the compose file's `environment:` block — extend it
# there to wire new keys.
