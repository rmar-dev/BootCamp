# Caddy reverse proxy — TLS termination + per-app routing.
#
# This file hosts BOTH BootCamp (always) and Constructhub (when CONSTRUCTHUB_DOMAIN is set).
# Each site has its own block; Caddy routes by Host header.
#
# Eliminating CORS: BootCamp serves /api/* from the same origin as the SPA.
# Constructhub's nginx already does that internally — Caddy just forwards.
#
# TLS: auto-Let's Encrypt for each domain. First request to a fresh domain
# pauses ~10–30s while the cert provisions.

# ── BootCamp ────────────────────────────────────────────────────────────────
{$BOOTCAMP_DOMAIN} {
	encode gzip zstd

	# Platform API (NestJS controllers under /api/*)
	handle /api/* {
		reverse_proxy platform:3002 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Optional Level-3 LSP WebSocket bridge (only if --profile lsp is up).
	@lsp {
		path /lsp /lsp/*
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @lsp {
		reverse_proxy swift-lsp:4500
	}

	# Next.js (catch-all)
	handle {
		reverse_proxy web:3001 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
	}
}

# ── Constructhub (only active when CONSTRUCTHUB_DOMAIN is non-empty) ────────
# The Constructhub stack's frontend container runs nginx that already
# proxies API paths to its own backend. Caddy just terminates TLS and
# forwards everything to the frontend container by name on the shared
# `web-edge` network.
{$CONSTRUCTHUB_DOMAIN} {
	encode gzip zstd

	handle {
		reverse_proxy constructhub-frontend:80 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
	}
}
