# BootCamp production env — copy to .env.prod and fill in the placeholders.
# bootstrap.sh generates secrets automatically; only DOMAIN + OAuth need
# manual values from you.

# ── Required ────────────────────────────────────────────────────────────────
# The domain you'll point at this VPS. Caddy gets a Let's Encrypt cert for it.
DOMAIN=demo.example.com

# Random 32-byte secrets — bootstrap.sh fills these in if left as placeholders.
# Rotate if ever exposed. Never reuse from a dev environment.
JWT_SECRET=<JWT_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>

# Postgres credentials — bootstrap.sh fills POSTGRES_PASSWORD automatically.
POSTGRES_USER=bootcamp
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=bootcamp

# ── Optional ────────────────────────────────────────────────────────────────
# Restricts new registrations to email addresses ending in this domain.
# Leave empty to allow any email.
ALLOWED_EMAIL_DOMAIN=

# Google OAuth — populate if you want Sign in with Google. Update the callback
# URL in https://console.cloud.google.com/apis/credentials to match:
#   https://${DOMAIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI code review — keep false unless you have an LLM endpoint configured.
AI_REVIEW_ENABLED=false
