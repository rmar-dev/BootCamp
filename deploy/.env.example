# BootCamp production env — copy to .env.prod and fill in the placeholders.
# bootstrap.sh generates secrets automatically; only the domain values + any
# OAuth credentials need manual values from you.

# ── BootCamp (always required) ──────────────────────────────────────────────
# The BootCamp domain. Caddy gets a Let's Encrypt cert for it.
# Also accepted as plain DOMAIN for back-compat with the original env.
BOOTCAMP_DOMAIN=bootcamp.example.com

# Random 32-byte secrets — bootstrap.sh fills these in if left as placeholders.
# Rotate if ever exposed. Never reuse from a dev environment.
JWT_SECRET=<JWT_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>

# BootCamp's Postgres credentials — bootstrap.sh fills POSTGRES_PASSWORD.
POSTGRES_USER=bootcamp
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=bootcamp

# Optional: lock new BootCamp registrations to a specific email domain.
ALLOWED_EMAIL_DOMAIN=

# Google OAuth for BootCamp (Sign in with Google).
# Update the callback URL in https://console.cloud.google.com/apis/credentials:
#   https://${BOOTCAMP_DOMAIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI code review — keep false unless you have an LLM endpoint configured.
AI_REVIEW_ENABLED=false

# ── Constructhub (optional second app on the same VPS) ──────────────────────
# Leave CONSTRUCTHUB_DOMAIN empty to skip hosting Constructhub.
# When set, run bootstrap.sh with `--with constructhub` to bring it up.
# Its own secrets live in deploy/sites/constructhub/.env.prod (auto-generated).
CONSTRUCTHUB_DOMAIN=
